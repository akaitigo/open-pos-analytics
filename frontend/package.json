{
	"name": "open-pos-analytics-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"test": "vitest run --exclude 'test/e2e/**' --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage --exclude 'test/e2e/**' --passWithNoTests",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"d3": "^7.9.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/d3": "^7.4.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.10",
		"oxlint": "^1.73.0",
		"typescript": "^5.7.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
